DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,app.example.com,192.168.1.4:8000
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com
DJANGO_SECURE_SSL_REDIRECT=True
PUBLIC_BASE_URL=https://app.example.com
WEB_RELEASE_VERSION=2026.04.20.1
WEB_RELEASE_POLL_INTERVAL_SECONDS=300

# Use one of the following database options.
# DATABASE_URL=postgres://botgi_user:botgi_password@db-host:5432/botgi_db
# SQLITE_PATH=C:\path\to\db.sqlite3
